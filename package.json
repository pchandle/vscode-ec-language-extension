{
  "name": "emergent-coding",
  "description": "The Emergent Coding extension adds language support for Emergent Coding to Visual Studio Code, including editing (IntelliSense) and debugging features.",
  "displayName": "Emergent Coding",
  "author": "Aptissio",
  "license": "MIT",
  "version": "0.11.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/aptissio/vscode-ec-language-extension"
  },
  "publisher": "aptissio",
  "icon": "ec_icon_256x256.png",
  "categories": [],
  "keywords": [
    "multi-root ready"
  ],
  "engines": {
    "vscode": "^1.75.0",
    "node": ">=18"
  },
  "main": "./client/dist/extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "Gateway",
        "properties": {
          "gateway.hostname": {
            "type": "string",
            "default": "localhost",
            "description": "Specifies the hostname or IPv4 address of the Emergent Coding Gateway server."
          },
          "gateway.port": {
            "type": "integer",
            "default": 10000,
            "description": "Specifies the TCP port of the Emergent Coding Gateway server."
          },
          "gateway.allowInsecure": {
            "type": "boolean",
            "default": true,
            "description": "Allow insecure conenctions to the Emergent Coding Gateway server."
          },
          "gateway.network": {
            "type": "string",
            "enum": [
              "31",
              "34"
            ],
            "default": "31",
            "description": "Select the Emergent network for API path prefixes (root/spec fetch)."
          }
        }
      },
      {
        "title": "Specification Cache",
        "properties": {
          "cache.specificationPath": {
            "type": "string",
            "enum": [
              "~/.emergent/contractCache.json"
            ],
            "default": "~/.emergent/contractCache.json",
            "markdownDescription": "Read-only location of the specification cache. Use the command 'Emergent: Clear Specification Cache' to wipe it."
          }
        }
      },
      {
        "title": "Formatting",
        "properties": {
          "formatting.disabled": {
            "type": "boolean",
            "default": false,
            "description": "Disable the native Emergent Coding formatting."
          }
        }
      },
      {
        "title": "Specification Defaults",
        "properties": {
          "specification.defaultSupplier": {
            "type": "string",
            "default": "",
            "description": "Default supplier value used when creating a new contract specification."
          },
          "specification.localContractRoot": {
            "type": "string",
            "default": "",
            "markdownDescription": "Local Contract Specification Root Directory. Select a folder to store and edit contract specifications.",
            "format": "uri"
          },
          "specification.localProtocolRoot": {
            "type": "string",
            "default": "",
            "markdownDescription": "Local Protocol Specification Root Directory. Select a folder to store and edit protocol specifications.",
            "format": "uri"
          },
          "specification.contractFilenameFormat": {
            "type": "string",
            "default": "{layer}--{verb}--{subject}--{variation}--{platform}",
            "markdownDescription": "Filename format for new contract specifications (extension is appended automatically: .cspec). Supported tokens: `{layer}`, `{verb}`, `{subject}`, `{variation}`, `{platform}`."
          },
          "specification.protocolFilenameFormat": {
            "type": "string",
            "default": "{layer}--{subject}--{variation}--{platform}",
            "markdownDescription": "Filename format for new protocol specifications (extension is appended automatically: .pspec). Supported tokens: `{layer}`, `{subject}`, `{variation}`, `{platform}`."
          }
        }
      },
      {
        "title": "Hover",
        "properties": {
          "emergent.hover.disabled": {
            "scope": "resource",
            "type": "boolean",
            "default": true,
            "description": "Disable hover popups for Emergent Coding files."
          }
        }
      },
      {
        "title": "Protocol Design Definitions",
        "properties": {
          "protocolDesign.definitionPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "markdownDescription": "List of protocol design definition (.pdd) files to choose from. Relative paths are resolved from the first workspace folder."
          },
          "protocolDesign.activeDefinition": {
            "type": "string",
            "default": "",
            "markdownDescription": "Path to the active .pdd file. If empty, the bundled default is used or the first valid entry from `protocolDesign.definitionPaths`."
          }
        }
      },
      {
        "title": "Extension Debugging",
        "properties": {
          "emergent.maxNumberOfProblems": {
            "scope": "resource",
            "type": "number",
            "default": 100,
            "description": "Controls the maximum number of problems produced by the language server."
          },
          "emergent.trace.server": {
            "scope": "window",
            "type": "string",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "verbose",
            "description": "Traces the communication between VS Code and the language server."
          },
          "emergent.hoverDebugLogging": {
            "scope": "window",
            "type": "boolean",
            "default": false,
            "description": "Emit detailed hover classification and fetch logging to the Language Server output."
          },
          "emergent.specCache.softTtlHours": {
            "scope": "window",
            "type": "number",
            "default": 24,
            "description": "Soft TTL for cached specifications in hours. Stale entries may still be served while refresh is attempted."
          },
          "emergent.specCache.fetchConcurrency": {
            "scope": "window",
            "type": "number",
            "default": 6,
            "description": "Maximum number of concurrent specification fetch requests."
          },
          "emergent.specCache.retryCount": {
            "scope": "window",
            "type": "number",
            "default": 2,
            "description": "Number of retry attempts for specification fetches after the initial request."
          },
          "emergent.specCache.retryBaseMs": {
            "scope": "window",
            "type": "number",
            "default": 250,
            "description": "Base backoff duration in milliseconds between specification fetch retries."
          },
          "emergent.specCache.allowStale": {
            "scope": "window",
            "type": "boolean",
            "default": true,
            "description": "Allow serving stale cached specifications while background refresh runs."
          },
          "emergent.autopilotExtension": {
            "scope": "window",
            "type": "string",
            "default": ".dla",
            "description": "Filename extension used for autopilot expressions in bulk validation scans."
          },
          "emergent.pilotExtension": {
            "scope": "window",
            "type": "string",
            "default": ".dlp",
            "description": "Filename extension used for pilot expressions in bulk validation scans."
          },
          "emergent.bulkValidationMode": {
            "scope": "window",
            "type": "string",
            "enum": [
              "autopilot",
              "pilot",
              "both"
            ],
            "default": "autopilot",
            "description": "Controls whether Bulk Expression Validation scans autopilot files, pilot files, or both."
          },
          "emergent.bulkValidationFolders": {
            "scope": "window",
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Workspace folder relative paths to include in Bulk Expression Validation. Empty means all workspace folders."
          }
        }
      }
    ],
    "languages": [
      {
        "id": "emergent",
        "aliases": [
          "Emergent Coding"
        ],
        "extensions": [
          ".dla",
          ".dlp",
          ".cspec",
          ".pspec"
        ],
        "configuration": "./conf/emergent.tmLanguage.json"
      }
    ],
    "grammars": [
      {
        "language": "emergent",
        "scopeName": "source.emergent",
        "path": "./conf/emergent.tmGrammar.json"
      }
    ],
    "themes": [
      {
        "label": "Design Domain Language",
        "uiTheme": "vs-dark",
        "path": "./conf/emergent.tmTheme.json"
      }
    ],
    "snippets": [
      {
        "language": "emergent",
        "path": "./conf/emergent.tmSnippets.json"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "emergent.bulkExpressionValidation",
          "name": "Bulk Expression Validation"
        }
      ]
    },
    "commands": [
      {
        "command": "emergent.showSpecificationPanel",
        "title": "Emergent: Show Specification Panel"
      },
      {
        "command": "emergent.openSpecificationAtPosition",
        "title": "Emergent: Open Specification at Position",
        "category": "Emergent"
      },
      {
        "command": "emergent.openLocalSpecificationAtPosition",
        "title": "Emergent: Open Local Specification at Position",
        "category": "Emergent"
      },
      {
        "command": "emergent.newProtocolSpec",
        "title": "Emergent: New Protocol Specification",
        "category": "Emergent"
      },
      {
        "command": "emergent.newContractSpec",
        "title": "Emergent: New Contract Specification",
        "category": "Emergent"
      },
      {
        "command": "emergent.reloadSpecifications",
        "title": "Emergent: Reload Specifications",
        "category": "Emergent"
      },
      {
        "command": "emergent.exportProtocolSpec",
        "title": "Emergent: Export Protocol Spec (from .pdes)",
        "category": "Emergent"
      },
      {
        "command": "emergent.clearSpecificationCache",
        "title": "Emergent: Clear Specification Cache",
        "category": "Emergent"
      },
      {
        "command": "emergent.startBulkExpressionValidation",
        "title": "Emergent: Start Bulk Expression Validation",
        "category": "Emergent",
        "icon": "$(play)"
      },
      {
        "command": "emergent.rescanBulkExpressionValidation",
        "title": "Emergent: Rescan Bulk Expression Validation",
        "category": "Emergent",
        "icon": "$(refresh)"
      },
      {
        "command": "emergent.nextBulkExpressionDiagnostic",
        "title": "Emergent: Next Bulk Expression File",
        "category": "Emergent",
        "icon": "$(arrow-right)"
      },
      {
        "command": "emergent.previousBulkExpressionDiagnostic",
        "title": "Emergent: Previous Bulk Expression File",
        "category": "Emergent",
        "icon": "$(arrow-left)"
      },
      {
        "command": "emergent.skipBulkExpressionDiagnostic",
        "title": "Emergent: Skip Bulk Expression File",
        "category": "Emergent",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "emergent.clearBulkExpressionValidation",
        "title": "Emergent: Clear Bulk Expression Validation",
        "category": "Emergent",
        "icon": "$(clear-all)"
      },
      {
        "command": "emergent.focusBulkExpressionValidation",
        "title": "Emergent: Focus Bulk Expression Validation",
        "category": "Emergent"
      }
    ],
    "keybindings": [
      {
        "command": "emergent.showSpecificationPanel",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorLangId == emergent"
      },
      {
        "command": "emergent.startBulkExpressionValidation",
        "key": "ctrl+alt+e ctrl+f",
        "mac": "cmd+alt+e cmd+f"
      },
      {
        "command": "emergent.nextBulkExpressionDiagnostic",
        "key": "ctrl+alt+e ctrl+n",
        "mac": "cmd+alt+e cmd+n"
      },
      {
        "command": "emergent.previousBulkExpressionDiagnostic",
        "key": "ctrl+alt+e ctrl+p",
        "mac": "cmd+alt+e cmd+p"
      },
      {
        "command": "emergent.skipBulkExpressionDiagnostic",
        "key": "ctrl+alt+e ctrl+s",
        "mac": "cmd+alt+e cmd+s"
      },
      {
        "command": "emergent.rescanBulkExpressionValidation",
        "key": "ctrl+alt+e ctrl+r",
        "mac": "cmd+alt+e cmd+r"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "emergent.startBulkExpressionValidation",
          "when": "view == emergent.bulkExpressionValidation",
          "group": "navigation@1"
        },
        {
          "command": "emergent.rescanBulkExpressionValidation",
          "when": "view == emergent.bulkExpressionValidation",
          "group": "navigation@2"
        },
        {
          "command": "emergent.nextBulkExpressionDiagnostic",
          "when": "view == emergent.bulkExpressionValidation",
          "group": "navigation@3"
        },
        {
          "command": "emergent.previousBulkExpressionDiagnostic",
          "when": "view == emergent.bulkExpressionValidation",
          "group": "navigation@4"
        },
        {
          "command": "emergent.skipBulkExpressionDiagnostic",
          "when": "view == emergent.bulkExpressionValidation",
          "group": "navigation@5"
        },
        {
          "command": "emergent.clearBulkExpressionValidation",
          "when": "view == emergent.bulkExpressionValidation",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "emergent.skipBulkExpressionDiagnostic",
          "when": "view == emergent.bulkExpressionValidation && viewItem == bulkValidationDiagnostic",
          "group": "inline@1"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "contractSpecEditor",
        "displayName": "Contract Specification Editor",
        "selector": [
          {
            "filenamePattern": "*.cspec"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "protocolSpecEditor",
        "displayName": "Protocol Specification Editor",
        "selector": [
          {
            "filenamePattern": "*.pspec"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "protocolDesignEditor",
        "displayName": "Protocol Design Editor",
        "selector": [
          {
            "filenamePattern": "*.pdes"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:webview && npm run bundle",
    "bundle": "npm run bundle:client && npm run bundle:server",
    "bundle:client": "esbuild client/src/extension.ts --bundle --platform=node --format=cjs --external:vscode --external:jsonc-parser --outfile=client/dist/extension.js --sourcemap",
    "bundle:server": "esbuild server/src/server.ts --bundle --platform=node --format=cjs --external:vscode --external:jsonc-parser --outfile=server/dist/server.js --sourcemap",
    "watch:client": "npm run bundle:client -- --watch",
    "watch:server": "npm run bundle:server -- --watch",
    "vscode:prepublish": "npm run build",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "typecheck:client": "tsc -p client/tsconfig.json --noEmit",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
    "build:webview": "node ./scripts/build-webview.js",
    "watch:webview": "node ./scripts/build-webview.js --watch",
    "test:validators": "TS_NODE_TRANSPILE_ONLY=1 TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"target\":\"es2020\",\"esModuleInterop\":true,\"resolveJsonModule\":true,\"moduleResolution\":\"node\",\"jsx\":\"react-jsx\"}' node -r ts-node/register ./scripts/test-precompiled-validators.ts",
    "test:compile-client": "tsc -p client/tsconfig.json",
    "test": "bash ./scripts/e2e.sh",
    "test:server": "npm run build:server && mocha \"server/out/test/**/*.test.js\"",
    "build:server": "tsc -p server/tsconfig.json && tsc -p server/tsconfig.test.json",
    "validate:corpus": "npm run build:server && node ./scripts/validate-dla-corpus.js",
    "validate:corpus:baseline": "npm run build:server && node ./scripts/validate-dla-corpus.js --update-baseline",
    "sync:spec-cache": "bash ./scripts/sync-spec-cache.sh",
    "hydrate:spec-cache": "npm run build:server && node ./scripts/hydrate-spec-cache.js",
    "triage:diagnostics": "node ./scripts/triage-diagnostics.js --limit 20",
    "triage:report": "node ./scripts/diagnostic-triage-report.js"
  },
  "devDependencies": {
    "@rjsf/core": "^5.18.3",
    "@rjsf/utils": "^5.18.3",
    "@rjsf/validator-ajv8": "^5.18.3",
    "@types/mocha": "^9.1.0",
    "@types/node": "^18.19.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "@vscode/test-electron": "^2.1.2",
    "chai": "^4.3.7",
    "esbuild": "^0.27.0",
    "eslint": "^8.13.0",
    "mocha": "^11.7.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.8.4"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "jsonc-parser": "^3.2.1"
  },
  "overrides": {
    "mocha": {
      "diff": "8.0.3",
      "serialize-javascript": "7.0.3"
    }
  },
  "configurationDefaults": {
    "[emergent]": {
      "editor.semanticHighlighting.enabled": true,
      "editor.bracketPairColorization.enabled": false,
      "editor.guides.bracketPairs": false
    }
  }
}
